SAY NAME2 @88 /*Bodhi's Skin*/
SAY DESC @89 /*Bodhi will not wear armor. She finds it confining.

STATISTICS:

Weight: 0*/

// EET related code & summoning script
ACTION_IF GAME_IS ~eet~ THEN BEGIN 
  INCLUDE ~EET/other/EET_functions.tph~ //declaration of external EET functions used below
  LAF ~EET_NPC_TRANSITION~ //function used to automatically implement EET continuity system
    INT_VAR
      type = 2 //informs the function that this is BG2 NPC without BG1 content
	  clean_ToB = 1
    STR_VAR
      dv = "YFBodhi" //Bodhi Death Variable (script name)
      override_SoA = "YFBodhi" //SoA Override script
      override_ToB = "YFBod25" //ToB Override script
      dialog_ToB = "YFBod25" //ToB dialogue file
	  cre_ToB = "YFBod25"
	  traFile = EVAL "BodhiNPC/translations/%LANGUAGE%/YFBod25.tra"
      string = "@0" /*Bring me Bodhi, the bloodthirsty vampire.*/
      stringPosDV = "Cernd" //Bodhi should be appended right above Cernd
	  clean_ToB_DV = "YFBodhi"
  END
  
 END ELSE BEGIN //different Fate Spirit dialogue patching for any other platform than EET
  COMPILE ~BodhiNPC/dialogues/YFFateSpBodhi.d~ USING ~BodhiNPC/translations/%LANGUAGE%/YFFateSpBodhi.tra~ //Other Fate Spirit dialogue, this says to use same tra as TOB file
END

//Code to make Malchor Harpell not come back after you kill him.
COPY_EXISTING ~baldur.bcs~ ~override~
  DECOMPILE_BCS_TO_BAF   //This code changes the game file to something Weidu can edit
    REPLACE_TEXTUALLY //This code says to replace every instance of the first ~~ with what's inside the second ~~
	~!Exists("c6harp")~
            ~!Exists("c6harp") !Dead("c6harp")~
  COMPILE_BAF_TO_BCS //This code then recompiles the file into a game file
BUT_ONLY_IF_IT_CHANGES  //To stop this from happening endlessly


//Bodhi Vampire
COPY ~BodhiNPC/epilogue/YFBodV.2da~ ~override/YFBodV1.2da~ //Vampire (all)
REPLACE ~99999~ @135

//Bodhi Elf
COPY ~BodhiNPC/epilogue/YFBodE.2da~ ~override/YFBodE1.2da~ //Elf (all)
REPLACE ~99999~ @136

//Crossmod files for Clara only
// ----- Clara 的跨 Mod (Crossmod) 内容 -----
// 检查游戏中是否存在 Saradas NPC 的角色文件 (!sartob.cre)。
// 这通常意味着 Saradas NPC Mod 已安装。
ACTION_IF FILE_EXISTS_IN_GAME ~YF_Clara.cre~ THEN BEGIN //This code detects the Saradas NPC and adds his banters with Clara
    // 如果检测到 Saradas，则打印信息。
 PRINT @150
     // 编译 Clara 与 Saradas 之间的互动对话文件。
OUTER_SET YFBodhiJoinsSoA5STATE = STATE_WHICH_SAYS 21 IN ~BodhiNPC\translations\%s\YFBodhi.tra~ FROM ~C6BODHI~
 COMPILE EVALUATE_BUFFER ~BodhiNPC/crossmod/YFBodhi.d~ 
 COMPILE ~BodhiNPC/crossmod/bYFBodhi.d~ 
 COMPILE ~BodhiNPC/crossmod/bYFBod25.d~ 
END ELSE BEGIN    // 如果未检测到 Saradas，则打印信息。
 PRINT @151
END // 结束 Saradas 不存在的处理块。